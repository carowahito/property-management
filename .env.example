# Database
DATABASE_URL="postgresql://user:password@localhost:5432/property_management"

# NextAuth Configuration
NEXTAUTH_URL="http://localhost:3001"
NEXTAUTH_SECRET="your-secret-key-generate-with-openssl-rand-base64-32"

# Email Service (SendGrid)
SENDGRID_API_KEY="your-sendgrid-api-key"
SENDGRID_FROM_EMAIL="noreply@yourcompany.com"

# SMS Service (Twilio)
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="+1234567890"

# WhatsApp Service - Option 1: Twilio (Easier Setup)
TWILIO_WHATSAPP_NUMBER="whatsapp:+14155238886"  # Use Twilio Sandbox or your approved number

# WhatsApp Service - Option 2: Meta Cloud API (Direct, No Middleman)
META_WHATSAPP_PHONE_NUMBER_ID="your-phone-number-id"  # From Meta Business Manager
META_WHATSAPP_ACCESS_TOKEN="your-permanent-access-token"  # From Meta Developer Console
WHATSAPP_PROVIDER="twilio"  # Options: "twilio" or "meta"

# AWS (Optional - for file uploads)
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_S3_BUCKET="your-bucket-name"

# Application
NODE_ENV="development"
APP_URL="http://localhost:3001"
PORT=3001

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000

# Feature Flags
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=false
ENABLE_WHATSAPP_NOTIFICATIONS=true
ENABLE_FILE_UPLOADS=true
