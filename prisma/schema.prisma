// Prisma Schema for Property Management System
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// Authentication & Users
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  password      String
  name          String?
  image         String?
  role          UserRole  @default(ADMIN)
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts      Account[]
  sessions      Session[]

  // Activity tracking
  assignedTasks Task[]    @relation("AssignedTasks")
  createdTasks  Task[]    @relation("CreatedTasks")
  messages      Message[] @relation("SentMessages")

  // Team member profile
  teamMember    TeamMember?

  @@index([email])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum UserRole {
  ADMIN
  MANAGER
  AGENT
  STAFF
}

// ============================================
// Core Entities
// ============================================

model Property {
  id          String   @id @default(cuid())
  name        String
  address     String
  city        String?
  state       String?
  postalCode  String?
  country     String   @default("Kenya")
  type        PropertyType
  totalUnits  Int      @default(1)
  yearBuilt   Int?
  status      PropertyStatus @default(ACTIVE)
  description String?
  // Optional: set if one landlord owns the entire building.
  // Leave null when different units are owned by different landlords.
  landlordId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  landlord    Landlord?    @relation(fields: [landlordId], references: [id], onDelete: SetNull)
  propertyUnits Unit[]
  tenants     Tenant[]
  leases      Lease[]
  maintenanceRequests MaintenanceRequest[]
  inspections Inspection[]
  viewings    Viewing[]
  messages    Message[]
  rentTransactions RentTransaction[]
  statements  LandlordStatement[]
  ownerStatements OwnerStatement[]
  deposits    Deposit[]
  applications TenantApplication[]
  arrearsEscalations ArrearsEscalation[]

  @@index([landlordId])
  @@index([status])
  @@map("properties")
}

model Unit {
  id            String     @id @default(cuid())
  // unitNumber is globally unique — it encodes the building prefix (e.g. GWG2-A55).
  // One active tenant at a time is enforced at the application layer.
  // A landlord can own many units: GWG2-A55, GWG2-A56, GWG2-A57, etc.
  unitNumber    String     @unique
  propertyId    String
  landlordId    String
  floor         Int?
  bedrooms      Int?
  bathrooms     Int?
  sizeSqm       Float?
  status        UnitStatus @default(VACANT)
  monthlyRent   Decimal?   @db.Decimal(10, 2)
  serviceCharge     Decimal?   @db.Decimal(10, 2)
  serviceChargeType FeeType    @default(FIXED)
  managementFee     Decimal?   @db.Decimal(10, 2)
  managementFeeType FeeType    @default(PERCENTAGE)
  description   String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // Relations
  property              Property               @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  landlord              Landlord               @relation(fields: [landlordId], references: [id], onDelete: Cascade)
  tenants               Tenant[]
  leases                Lease[]
  rentTransactions      RentTransaction[]
  payouts               Payout[]
  distributionItems     RentDistributionItem[]
  applications          TenantApplication[]

  @@index([propertyId])
  @@index([landlordId])
  @@index([status])
  @@map("units")
}

model Landlord {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  phone       String
  idNumber    String?  @unique
  address     String?
  bankName    String?
  bankAccount String?
  taxId       String?
  status      StakeholderStatus @default(ACTIVE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  properties  Property[]
  units       Unit[]
  payouts     Payout[]
  messages    Message[]
  rentTransactions RentTransaction[]
  statements  LandlordStatement[]
  ownerStatements OwnerStatement[]

  @@index([email])
  @@index([status])
  @@map("landlords")
}

model Tenant {
  id              String   @id @default(cuid())
  name            String
  email           String   @unique
  phone           String
  idNumber        String?  @unique
  emergencyContact String?
  emergencyPhone  String?
  propertyId      String
  unitId          String?
  unit            String?  // kept for backward compatibility
  moveInDate      DateTime?
  moveOutDate     DateTime?
  status          TenantStatus @default(ACTIVE)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unitRef         Unit?     @relation(fields: [unitId], references: [id], onDelete: SetNull)
  leases          Lease[]
  payments        Payment[]
  maintenanceRequests MaintenanceRequest[]
  messages        Message[]
  rentTransactions RentTransaction[]
  deposits        Deposit[]
  arrearsEscalations ArrearsEscalation[]

  @@index([email])
  @@index([propertyId])
  @@index([unitId])
  @@index([status])
  @@map("tenants")
}

model Vendor {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  phone          String
  specialization String
  rating         Float    @default(0)
  status         StakeholderStatus @default(ACTIVE)
  address        String?
  licenseNumber  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  workOrders     WorkOrder[]
  messages       Message[]

  @@index([email])
  @@index([specialization])
  @@index([status])
  @@map("vendors")
}

model Lead {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String
  type        LeadType @default(TENANT)
  status      LeadStatus @default(NEW)
  source      LeadSource @default(WEBSITE)
  budget      String?
  moveInDate  DateTime?
  preferences String?
  notes       String?
  assignedTo  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastContact DateTime?
  convertedAt DateTime?

  // Relations
  tasks       Task[]
  communications Communication[]
  notes_rel   Note[]

  @@index([email])
  @@index([status])
  @@index([assignedTo])
  @@map("leads")
}

model Enquiry {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String
  subject     String
  message     String
  status      EnquiryStatus @default(OPEN)
  priority    Priority @default(MEDIUM)
  assignedTo  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  resolvedAt  DateTime?
  propertyId  String?

  // Relations
  tasks       Task[]
  communications Communication[]
  notes_rel   Note[]

  @@index([email])
  @@index([status])
  @@index([priority])
  @@map("enquiries")
}

// ============================================
// Financial
// ============================================

model LeaseTemplate {
  id              String   @id @default(cuid())
  name            String
  type            LeaseTemplateType
  content         String   @db.Text  // HTML with {{placeholders}}
  clauses         Json?    // JSON array of clause objects: { id, title, text, required, enabled }
  isDefault       Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  leases          Lease[]

  @@map("lease_templates")
}

enum LeaseTemplateType {
  RESIDENTIAL_STANDARD
  RESIDENTIAL_SHORT_TERM
  COMMERCIAL
}

model Lease {
  id              String   @id @default(cuid())
  tenantId        String
  propertyId      String
  unitId          String?
  unit            String?  // kept for backward compatibility
  startDate       DateTime
  endDate         DateTime
  monthlyRent     Decimal  @db.Decimal(10, 2)
  securityDeposit Decimal  @db.Decimal(10, 2)
  status          LeaseStatus @default(ACTIVE)
  terms           String?

  // Template & Document
  templateId      String?
  documentHtml    String?  @db.Text  // Rendered HTML document
  noticePeriod    Int      @default(1) // months
  rentEscalation  Decimal? @db.Decimal(5, 2) // annual % increase
  petPolicy       String?
  specialConditions String? @db.Text

  // Signing
  sentForSigning  Boolean  @default(false)
  sentAt          DateTime?
  tenantSignedAt  DateTime?
  landlordSignedAt DateTime?
  tenantSignature String?  // base64 or "DIGITALLY_SIGNED"
  landlordSignature String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property        Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unitRef         Unit?    @relation(fields: [unitId], references: [id], onDelete: SetNull)
  template        LeaseTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  payments        Payment[]
  rentTransactions RentTransaction[]
  workOrders      WorkOrder[]
  deposits        Deposit[]
  arrearsEscalations ArrearsEscalation[]

  @@index([tenantId])
  @@index([propertyId])
  @@index([unitId])
  @@index([templateId])
  @@index([status])
  @@map("leases")
}

model Payment {
  id              String   @id @default(cuid())
  tenantId        String
  leaseId         String
  amount          Decimal  @db.Decimal(10, 2)
  type            PaymentType @default(RENT)
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  dueDate         DateTime
  paidDate        DateTime?
  // reference = Receipt No / Transaction ID (e.g. "UC6SN7KEF6").
  // Unique when present — use this to look up any transaction.
  reference       String?  @unique
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lease           Lease    @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  rentTransaction RentTransaction?

  @@index([tenantId])
  @@index([leaseId])
  @@index([status])
  @@index([dueDate])
  @@map("payments")
}

model Payout {
  id          String   @id @default(cuid())
  landlordId  String
  unitId      String   // payout is always for a specific unit's income
  amount      Decimal  @db.Decimal(10, 2)
  period      String
  status      PayoutStatus @default(PENDING)
  method      PaymentMethod
  reference   String?  @unique
  notes       String?
  paidDate    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  landlord         Landlord         @relation(fields: [landlordId], references: [id], onDelete: Cascade)
  unit             Unit             @relation(fields: [unitId], references: [id], onDelete: Cascade)
  rentTransactions RentTransaction[]

  @@index([landlordId])
  @@index([unitId])
  @@index([status])
  @@map("payouts")
}

// ============================================
// Rent Distribution & Statements
// ============================================

model RentTransaction {
  id                String   @id @default(cuid())
  paymentId         String   @unique

  // Core chain: transactionId + tenantId + unitId fully identifies a transaction.
  // landlordId and propertyId are denormalized from unit for query performance —
  // they are set automatically from the unit when a transaction is created.
  tenantId          String
  unitId            String   // FK to Unit → auto-derives landlordId + propertyId
  leaseId           String
  landlordId        String   // denormalized from unit.landlordId
  propertyId        String   // denormalized from unit.propertyId

  // Rent Details
  grossRent         Decimal  @db.Decimal(10, 2)
  rentPeriod        String   // e.g., "November 2025"
  dueDate           DateTime
  paidDate          DateTime

  // Deductions
  serviceCharge     Decimal  @db.Decimal(10, 2) @default(0) // Monthly service charge
  managementFee     Decimal  @db.Decimal(10, 2) @default(0) // Management commission
  maintenanceFees   Decimal  @db.Decimal(10, 2) @default(0) // Agreed maintenance costs
  otherDeductions   Decimal  @db.Decimal(10, 2) @default(0) // Other agreed deductions
  totalDeductions   Decimal  @db.Decimal(10, 2)

  // Net Amount
  netAmount         Decimal  @db.Decimal(10, 2) // Amount paid to landlord

  // Late Fees (Property Manager Income — not shown to landlord)
  lateFees          Decimal  @db.Decimal(10, 2) @default(0)

  // Payout Details
  payoutId          String?
  payoutStatus      PayoutStatus @default(PENDING)
  payoutDate        DateTime?
  payoutMethod      PaymentMethod?
  payoutReference   String?

  // Metadata
  notes             String?
  processed         Boolean  @default(false)
  processedAt       DateTime?
  processedBy       String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  payment           Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unit              Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  lease             Lease    @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  landlord          Landlord @relation(fields: [landlordId], references: [id], onDelete: Cascade)
  property          Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  payout            Payout?  @relation(fields: [payoutId], references: [id], onDelete: SetNull)
  distributionItems RentDistributionItem[]

  @@index([paymentId])
  @@index([tenantId])
  @@index([unitId])
  @@index([leaseId])
  @@index([landlordId])
  @@index([propertyId])
  @@index([rentPeriod])
  @@index([payoutStatus])
  @@map("rent_transactions")
}

model RentDistributionItem {
  id                  String   @id @default(cuid())
  rentTransactionId   String
  // Direct unit link — service charge, repairs, agent commission are all
  // for a specific unit regardless of which transaction they belong to.
  unitId              String

  // Distribution Details
  type                DistributionType  // SERVICE_CHARGE | MANAGEMENT_FEE | MAINTENANCE_FEE | REPAIR_COST | NET_PAYOUT etc.
  description         String
  amount              Decimal  @db.Decimal(10, 2)
  recipientType       RecipientType     // LANDLORD | MANAGER | SERVICE_PROVIDER | VENDOR etc.
  recipientId         String?
  recipientName       String?

  // Payment Details
  paid                Boolean  @default(false)
  paidDate            DateTime?
  paymentMethod       PaymentMethod?
  reference           String?  @unique  // receipt/transaction ID for this specific line item

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  rentTransaction     RentTransaction @relation(fields: [rentTransactionId], references: [id], onDelete: Cascade)
  unit                Unit            @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([rentTransactionId])
  @@index([unitId])
  @@index([type])
  @@index([recipientType])
  @@map("rent_distribution_items")
}

model LandlordStatement {
  id              String   @id @default(cuid())
  landlordId      String
  propertyId      String?
  
  // Statement Period
  period          String   // e.g., "November 2025"
  startDate       DateTime
  endDate         DateTime
  
  // Financial Summary
  totalGrossRent       Decimal  @db.Decimal(10, 2)
  totalServiceCharges  Decimal  @db.Decimal(10, 2)
  totalManagementFees  Decimal  @db.Decimal(10, 2)
  totalMaintenanceFees Decimal  @db.Decimal(10, 2)
  totalOtherDeductions Decimal  @db.Decimal(10, 2)
  totalDeductions      Decimal  @db.Decimal(10, 2)
  totalNetAmount       Decimal  @db.Decimal(10, 2)
  
  // Metadata
  transactionCount Int      @default(0)
  generated        Boolean  @default(false)
  generatedAt      DateTime?
  generatedBy      String?
  sent             Boolean  @default(false)
  sentAt           DateTime?
  
  // Export
  pdfUrl           String?
  
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  landlord         Landlord @relation(fields: [landlordId], references: [id], onDelete: Cascade)
  property         Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  @@unique([landlordId, period, propertyId])
  @@index([landlordId])
  @@index([period])
  @@index([startDate, endDate])
  @@map("landlord_statements")
}

model OwnerStatement {
  id              String   @id @default(cuid())
  landlordId      String
  propertyId      String?  // null = consolidated portfolio statement

  month           Int      // 1-12
  year            Int

  // Revenue
  rentDue         Decimal  @db.Decimal(10, 2)
  rentReceived    Decimal  @db.Decimal(10, 2)

  // Deductions
  managementFee   Decimal  @db.Decimal(10, 2)
  managementFeeRate Decimal @db.Decimal(5, 2) // percentage
  maintenanceCosts Decimal @db.Decimal(10, 2) @default(0)
  otherDeductions Decimal  @db.Decimal(10, 2) @default(0)

  // Result
  netDisbursement Decimal  @db.Decimal(10, 2)
  depositsHeld    Decimal  @db.Decimal(10, 2) @default(0)

  // Line items detail
  lineItems       Json?    // Array: [{description, amount, type: 'income'|'deduction'}]

  // Status
  status          StatementStatus @default(DRAFT)
  generatedAt     DateTime @default(now())
  sentAt          DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  landlord        Landlord @relation(fields: [landlordId], references: [id])
  property        Property? @relation(fields: [propertyId], references: [id])

  @@unique([landlordId, propertyId, month, year])
  @@index([landlordId])
  @@index([propertyId])
  @@index([month, year])
  @@map("owner_statements")
}

enum StatementStatus {
  DRAFT
  FINALIZED
  SENT
}

// ============================================
// Deposits
// ============================================

model Deposit {
  id              String   @id @default(cuid())
  tenantId        String
  leaseId         String
  propertyId      String
  amount          Decimal  @db.Decimal(10, 2)
  paymentDate     DateTime
  paymentMethod   PaymentMethod @default(MPESA)
  paymentReference String?
  status          DepositStatus @default(HELD)

  // Settlement
  deductions      Json?    // Array: [{description, amount, evidenceUrl}]
  refundAmount    Decimal? @db.Decimal(10, 2)
  refundDate      DateTime?
  refundReference String?
  settlementNotes String?  @db.Text

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  lease           Lease    @relation(fields: [leaseId], references: [id])
  property        Property @relation(fields: [propertyId], references: [id])

  @@index([tenantId])
  @@index([leaseId])
  @@index([propertyId])
  @@index([status])
  @@map("deposits")
}

enum DepositStatus {
  HELD
  UNDER_REVIEW
  PARTIALLY_REFUNDED
  REFUNDED
  FORFEITED
}

// ============================================
// Operations
// ============================================

model MaintenanceRequest {
  id          String   @id @default(cuid())
  tenantId    String
  propertyId  String
  unit        String?
  title       String
  description String
  priority    Priority @default(MEDIUM)
  status      MaintenanceStatus @default(PENDING)
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  resolvedAt  DateTime?

  // Relations
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  workOrders  WorkOrder[]

  @@index([tenantId])
  @@index([propertyId])
  @@index([status])
  @@index([priority])
  @@map("maintenance_requests")
}

model WorkOrder {
  id                    String   @id @default(cuid())
  maintenanceRequestId  String?
  vendorId              String?
  leaseId               String?
  title                 String
  description           String
  status                WorkOrderStatus @default(PENDING)
  priority              Priority @default(MEDIUM)
  estimatedCost         Decimal? @db.Decimal(10, 2)
  actualCost            Decimal? @db.Decimal(10, 2)
  cost                  Decimal? @db.Decimal(10, 2) // Billable cost
  landlordApproved      Boolean  @default(false)
  scheduledDate         DateTime?
  completedDate         DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  maintenanceRequest    MaintenanceRequest? @relation(fields: [maintenanceRequestId], references: [id], onDelete: SetNull)
  vendor                Vendor?             @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  lease                 Lease?              @relation(fields: [leaseId], references: [id], onDelete: SetNull)

  @@index([vendorId])
  @@index([leaseId])
  @@index([status])
  @@map("work_orders")
}

model Inspection {
  id          String   @id @default(cuid())
  propertyId  String
  type        InspectionType
  date        DateTime
  inspector   String
  findings    String?
  status      InspectionStatus @default(SCHEDULED)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([date])
  @@map("inspections")
}

model Viewing {
  id          String   @id @default(cuid())
  propertyId  String
  visitorName String
  visitorEmail String
  visitorPhone String
  scheduledDate DateTime
  status      ViewingStatus @default(SCHEDULED)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([scheduledDate])
  @@map("viewings")
}

// ============================================
// CRM & Communications
// ============================================

model Task {
  id              String   @id @default(cuid())
  title           String
  description     String
  priority        Priority @default(MEDIUM)
  status          TaskStatus @default(PENDING)
  dueDate         DateTime
  reminderDate    DateTime?
  assignedToId    String
  assignedById    String
  stakeholderType StakeholderType?
  stakeholderId   String?
  leadId          String?
  enquiryId       String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  completedAt     DateTime?

  // Relations
  assignedTo      User     @relation("AssignedTasks", fields: [assignedToId], references: [id], onDelete: Cascade)
  assignedBy      User     @relation("CreatedTasks", fields: [assignedById], references: [id], onDelete: Cascade)
  lead            Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  enquiry         Enquiry? @relation(fields: [enquiryId], references: [id], onDelete: SetNull)

  @@index([assignedToId])
  @@index([status])
  @@index([dueDate])
  @@map("tasks")
}

model Communication {
  id              String   @id @default(cuid())
  type            CommunicationType
  direction       Direction
  subject         String?
  content         String
  status          CommunicationStatus @default(SENT)
  sentAt          DateTime @default(now())
  leadId          String?
  enquiryId       String?

  // Relations
  lead            Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  enquiry         Enquiry? @relation(fields: [enquiryId], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([enquiryId])
  @@map("communications")
}

model Message {
  id              String   @id @default(cuid())
  type            MessageType
  category        MessageCategory
  direction       Direction
  stakeholderType StakeholderType
  stakeholderId   String
  subject         String
  content         String
  sentById        String
  sentAt          DateTime @default(now())
  status          MessageStatus @default(SENT)
  propertyId      String?
  relatedTo       String?
  attachments     String[]

  // Relations
  sentBy          User      @relation("SentMessages", fields: [sentById], references: [id], onDelete: Cascade)
  property        Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  tenant          Tenant?   @relation(fields: [stakeholderId], references: [id], onDelete: Cascade, map: "messages_tenant_fkey")
  landlord        Landlord? @relation(fields: [stakeholderId], references: [id], onDelete: Cascade, map: "messages_landlord_fkey")
  vendor          Vendor?   @relation(fields: [stakeholderId], references: [id], onDelete: Cascade, map: "messages_vendor_fkey")

  @@index([stakeholderId])
  @@index([sentById])
  @@map("messages")
}

model Note {
  id        String   @id @default(cuid())
  content   String
  authorId  String
  leadId    String?
  enquiryId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  lead      Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  enquiry   Enquiry? @relation(fields: [enquiryId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([enquiryId])
  @@map("notes")
}

// ============================================
// Tenant Applications & Screening
// ============================================

model TenantApplication {
  id                String   @id @default(cuid())
  propertyId        String
  unitId            String?

  // Applicant Info
  fullName          String
  email             String
  phone             String
  idNumber          String
  currentAddress    String?

  // Employment
  employer          String?
  jobTitle          String?
  monthlyIncome     Decimal? @db.Decimal(10, 2)
  employmentDuration String? // e.g., "2 years"

  // References
  previousLandlord  String?
  previousLandlordPhone String?
  personalReference String?
  personalReferencePhone String?

  // Screening Results
  status            ApplicationStatus @default(SUBMITTED)
  incomeCheckPassed Boolean?   // income >= 3x rent
  crbCheckStatus    String?    // PASS / REFER / FAIL
  crbCheckDate      DateTime?
  employerVerified  Boolean?
  employerVerifyNotes String?
  landlordRefChecked Boolean?
  landlordRefNotes   String?

  // Decision
  screeningNotes    String?  @db.Text
  decidedBy         String?
  decidedAt         DateTime?
  landlordApproved  Boolean?
  landlordApprovalDate DateTime?

  // If approved, link to created tenant
  convertedTenantId String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  property          Property @relation(fields: [propertyId], references: [id])
  unit              Unit?    @relation(fields: [unitId], references: [id])

  @@index([propertyId])
  @@index([status])
  @@map("tenant_applications")
}

enum ApplicationStatus {
  SUBMITTED
  DOCUMENTS_PENDING
  SCREENING
  APPROVED
  REJECTED
  LANDLORD_REVIEW
  CONVERTED
  WITHDRAWN
}

