// ============================================
// Arrears Escalation & Management
// ============================================

model ArrearsEscalation {
  id              String   @id @default(cuid())
  leaseId         String
  tenantId        String
  propertyId      String

  rentAmount      Decimal  @db.Decimal(10, 2)
  amountOwed      Decimal  @db.Decimal(10, 2)
  daysOverdue     Int      @default(0)

  // Escalation steps
  currentStep     ArrearsStep @default(REMINDER_SENT)
  reminderSentAt  DateTime?   // Day 1
  notice1SentAt   DateTime?   // Day 6
  phoneCallAt     DateTime?   // Day 10
  phoneCallNotes  String?
  notice2SentAt   DateTime?   // Day 14
  landlordNotifiedAt DateTime? // Day 14
  formalNoticeAt  DateTime?   // Day 21
  legalReferralAt DateTime?   // Day 35+

  // Resolution
  resolvedAt      DateTime?
  resolution      String?  // PAID / PAYMENT_PLAN / EVICTION / VACATED
  notes           String?  @db.Text

  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  lease           Lease    @relation(fields: [leaseId], references: [id])
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  property        Property @relation(fields: [propertyId], references: [id])

  @@index([leaseId])
  @@index([tenantId])
  @@index([isActive])
  @@index([currentStep])
  @@map("arrears_escalations")
}

enum ArrearsStep {
  REMINDER_SENT
  OVERDUE_NOTICE_1
  PHONE_CALL
  OVERDUE_NOTICE_2
  FORMAL_NOTICE
  LEGAL_REFERRAL
  RESOLVED
}
