{
  "name": "tochi-property",
  "version": "1.0.0",
  "private": true,
  "description": "Tochi Property monorepo — marketing site and operations portal",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:marketing": "turbo run dev --filter=@tochi/marketing",
    "dev:portal": "turbo run dev --filter=@tochi/portal",
    "build": "turbo run build",
    "build:marketing": "turbo run build --filter=@tochi/marketing",
    "build:portal": "turbo run build --filter=@tochi/portal",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "prettier": "^3.3.3",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.17"
  }
}
