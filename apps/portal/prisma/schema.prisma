// Prisma Schema for Property Management System
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

// ============================================
// Multi-Tenancy
// ============================================

model Company {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique  // URL-safe identifier, e.g. "tochi-property"
  email         String?
  phone         String?
  address       String?
  city          String?
  country       String   @default("Kenya")
  logo          String?
  website       String?
  taxId         String?  // KRA PIN
  businessReg   String?  // Business registration number
  status        CompanyStatus @default(ACTIVE)
  plan          CompanyPlan   @default(FREE)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  users             User[]
  properties        Property[]
  landlords         Landlord[]
  tenants           Tenant[]
  vendors           Vendor[]
  contractors       Contractor[]
  leads             Lead[]
  enquiries         Enquiry[]
  leaseTemplates    LeaseTemplate[]
  gatewayTransactions GatewayTransaction[]
  invitations       Invitation[]

  @@index([slug])
  @@index([status])
  @@map("companies")
}

enum CompanyStatus {
  ACTIVE
  SUSPENDED
  INACTIVE
}

enum CompanyPlan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

// ============================================
// Authentication & Users
// ============================================

model User {
  id            String    @id @default(cuid())
  companyId     String
  email         String
  emailVerified DateTime?
  password      String
  name          String?
  image         String?
  role          UserRole  @default(ADMIN)
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  accounts      Account[]
  sessions      Session[]

  // Activity tracking
  assignedTasks Task[]    @relation("AssignedTasks")
  createdTasks  Task[]    @relation("CreatedTasks")
  messages      Message[] @relation("SentMessages")

  // Team member profile
  teamMember    TeamMember?

  @@unique([companyId, email])
  @@index([email])
  @@index([companyId])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum UserRole {
  ADMIN
  MANAGER
  AGENT
  STAFF
}

// ============================================
// Core Entities
// ============================================

model Property {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  address     String
  city        String?
  state       String?
  postalCode  String?
  country     String   @default("Kenya")
  type        PropertyType
  totalUnits  Int      @default(1)
  yearBuilt   Int?
  status      PropertyStatus @default(ACTIVE)
  description String?
  // Optional: set if one landlord owns the entire building.
  // Leave null when different units are owned by different landlords.
  landlordId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  landlord    Landlord?    @relation(fields: [landlordId], references: [id], onDelete: SetNull)
  propertyUnits Unit[]
  tenants     Tenant[]
  leases      Lease[]
  maintenanceRequests MaintenanceRequest[]
  inspections Inspection[]
  viewings    Viewing[]
  messages    Message[]
  rentTransactions RentTransaction[]
  statements  LandlordStatement[]
  ownerStatements OwnerStatement[]
  deposits    Deposit[]
  applications TenantApplication[]
  arrearsEscalations ArrearsEscalation[]
  moveInChecklists MoveInChecklist[]
  renewals    LeaseRenewal[]

  @@index([companyId])
  @@index([landlordId])
  @@index([status])
  @@map("properties")
}

model Unit {
  id            String     @id @default(cuid())
  // unitNumber is globally unique — it encodes the building prefix (e.g. GWG2-A55).
  // One active tenant at a time is enforced at the application layer.
  // A landlord can own many units: GWG2-A55, GWG2-A56, GWG2-A57, etc.
  unitNumber    String     @unique
  propertyId    String
  landlordId    String
  floor         Int?
  bedrooms      Int?
  bathrooms     Int?
  sizeSqm       Float?
  status        UnitStatus @default(VACANT)
  monthlyRent   Decimal?   @db.Decimal(10, 2)
  serviceCharge     Decimal?   @db.Decimal(10, 2)
  serviceChargeType FeeType    @default(FIXED)
  managementFee     Decimal?   @db.Decimal(10, 2)
  managementFeeType FeeType    @default(PERCENTAGE)
  description   String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // Relations
  property              Property               @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  landlord              Landlord               @relation(fields: [landlordId], references: [id], onDelete: Cascade)
  tenants               Tenant[]
  leases                Lease[]
  rentTransactions      RentTransaction[]
  ledgerEntries         TenantLedger[]
  payouts               Payout[]
  distributionItems     RentDistributionItem[]
  applications          TenantApplication[]
  inspections           Inspection[]

  @@index([propertyId])
  @@index([landlordId])
  @@index([status])
  @@map("units")
}

model Landlord {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  email       String
  phone       String
  idNumber    String?
  address     String?
  bankName    String?
  bankAccount String?
  taxId       String?
  status      StakeholderStatus @default(ACTIVE)

  // Commission defaults — applied to new units for this landlord
  managementFeePercent   Decimal?  @db.Decimal(10, 2) // value: % or fixed KES amount
  managementFeeType      String    @default("PERCENTAGE") // "PERCENTAGE" | "FIXED"
  tenantPlacementFee     Decimal?  @db.Decimal(5, 2)  // value: months (0.5 steps) or %
  tenantPlacementFeeType String    @default("MONTHS")  // "MONTHS" | "PERCENTAGE"

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  company     Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  properties  Property[]
  units       Unit[]
  payouts     Payout[]
  messages    Message[]
  rentTransactions RentTransaction[]
  statements  LandlordStatement[]
  ownerStatements OwnerStatement[]
  invitations     Invitation[]
  documents   LandlordDocument[]

  @@unique([companyId, email])
  @@index([email])
  @@index([companyId])
  @@index([status])
  @@map("landlords")
}

model LandlordDocument {
  id          String   @id @default(cuid())
  landlordId  String
  name        String
  fileType    String
  fileSize    Int
  storagePath String   @default("")
  url         String   @default("")
  content     String?  // base64 fallback when Supabase Storage not available
  uploadedAt  DateTime @default(now())

  landlord    Landlord @relation(fields: [landlordId], references: [id], onDelete: Cascade)

  @@index([landlordId])
  @@map("landlord_documents")
}

model Tenant {
  id              String   @id @default(cuid())
  companyId       String
  name            String
  email           String
  phone           String
  idNumber        String?
  emergencyContact String?
  emergencyPhone  String?
  propertyId      String?
  unitId          String?
  unit            String?  // kept for backward compatibility
  moveInDate      DateTime?
  moveOutDate     DateTime?
  status          TenantStatus @default(ACTIVE)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  property        Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unitRef         Unit?     @relation(fields: [unitId], references: [id], onDelete: SetNull)
  leases          Lease[]
  payments        Payment[]
  maintenanceRequests MaintenanceRequest[]
  messages        Message[]
  rentTransactions RentTransaction[]
  ledgerEntries   TenantLedger[]
  deposits        Deposit[]
  arrearsEscalations ArrearsEscalation[]
  moveInChecklists MoveInChecklist[]
  inspections      Inspection[]
  renewals         LeaseRenewal[]
  invitations      Invitation[]

  @@unique([companyId, email])
  @@index([email])
  @@index([companyId])
  @@index([propertyId])
  @@index([unitId])
  @@index([status])
  @@map("tenants")
}

model Vendor {
  id             String   @id @default(cuid())
  companyId      String
  name           String
  email          String
  phone          String
  specialization String
  rating         Float    @default(0)
  status         StakeholderStatus @default(ACTIVE)
  address        String?
  licenseNumber  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  workOrders     WorkOrder[]
  messages       Message[]
  invitations    Invitation[]

  @@unique([companyId, email])
  @@index([email])
  @@index([companyId])
  @@index([specialization])
  @@index([status])
  @@map("vendors")
}

model Lead {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  email       String
  phone       String
  type        LeadType @default(TENANT)
  status      LeadStatus @default(NEW)
  source      LeadSource @default(WEBSITE)
  budget      String?
  moveInDate  DateTime?
  preferences String?
  notes       String?
  assignedTo  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastContact DateTime?
  convertedAt DateTime?

  // Relations
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tasks       Task[]
  communications Communication[]
  notes_rel   Note[]

  @@index([email])
  @@index([companyId])
  @@index([status])
  @@index([assignedTo])
  @@map("leads")
}

model Enquiry {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  email       String
  phone       String
  subject     String
  message     String
  status      EnquiryStatus @default(OPEN)
  priority    Priority @default(MEDIUM)
  assignedTo  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  resolvedAt  DateTime?
  propertyId  String?

  // Relations
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tasks       Task[]
  communications Communication[]
  notes_rel   Note[]

  @@index([email])
  @@index([companyId])
  @@index([status])
  @@index([priority])
  @@map("enquiries")
}

// ============================================
// Financial
// ============================================

model LeaseTemplate {
  id              String   @id @default(cuid())
  companyId       String
  name            String
  type            LeaseTemplateType
  content         String   @db.Text  // HTML with {{placeholders}}
  clauses         Json?    // JSON array of clause objects: { id, title, text, required, enabled }
  isDefault       Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  leases          Lease[]

  @@index([companyId])
  @@map("lease_templates")
}

enum LeaseTemplateType {
  RESIDENTIAL_STANDARD
  RESIDENTIAL_SHORT_TERM
  COMMERCIAL
}

model Lease {
  id              String   @id @default(cuid())
  tenantId        String
  propertyId      String
  unitId          String?
  unit            String?  // kept for backward compatibility
  startDate       DateTime
  endDate         DateTime
  monthlyRent     Decimal  @db.Decimal(10, 2)
  securityDeposit Decimal  @db.Decimal(10, 2)
  status          LeaseStatus @default(ACTIVE)
  terms           String?

  // Template & Document
  templateId      String?
  documentHtml    String?  @db.Text  // Rendered HTML document
  noticePeriod    Int      @default(1) // months
  rentEscalation  Decimal? @db.Decimal(5, 2) // annual % increase
  petPolicy       String?
  specialConditions String? @db.Text

  // Signing
  sentForSigning  Boolean  @default(false)
  sentAt          DateTime?
  tenantSignedAt  DateTime?
  landlordSignedAt DateTime?
  tenantSignature String?  // base64 or "DIGITALLY_SIGNED"
  landlordSignature String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property        Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unitRef         Unit?    @relation(fields: [unitId], references: [id], onDelete: SetNull)
  template        LeaseTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  payments        Payment[]
  rentTransactions RentTransaction[]
  ledgerEntries   TenantLedger[]
  workOrders      WorkOrder[]
  deposits        Deposit[]
  arrearsEscalations ArrearsEscalation[]
  moveInChecklist MoveInChecklist?
  inspections     Inspection[]
  renewals        LeaseRenewal[]

  @@index([tenantId])
  @@index([propertyId])
  @@index([unitId])
  @@index([templateId])
  @@index([status])
  @@map("leases")
}

model Payment {
  id              String   @id @default(cuid())
  tenantId        String
  leaseId         String
  amount          Decimal  @db.Decimal(10, 2)
  type            PaymentType @default(RENT)
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  dueDate         DateTime
  paidDate        DateTime?
  // reference = Receipt No / Transaction ID (e.g. "UC6SN7KEF6").
  // Unique when present — use this to look up any transaction.
  reference       String?  @unique
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lease           Lease    @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  rentTransactions RentTransaction[]
  ledgerEntries   TenantLedger[]

  @@index([tenantId])
  @@index([leaseId])
  @@index([status])
  @@index([dueDate])
  @@map("payments")
}

model Payout {
  id          String   @id @default(cuid())
  landlordId  String
  unitId      String   // payout is always for a specific unit's income
  amount      Decimal  @db.Decimal(10, 2)
  period      String
  status      PayoutStatus @default(PENDING)
  method      PaymentMethod
  reference   String?  @unique
  notes       String?
  paidDate    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  landlord         Landlord         @relation(fields: [landlordId], references: [id], onDelete: Cascade)
  unit             Unit             @relation(fields: [unitId], references: [id], onDelete: Cascade)
  rentTransactions RentTransaction[]

  @@index([landlordId])
  @@index([unitId])
  @@index([status])
  @@map("payouts")
}

// ============================================
// Tenant Ledger (Statement of Account)
// ============================================

model TenantLedger {
  id            String   @id @default(cuid())
  tenantId      String
  leaseId       String
  unitId        String

  date          DateTime            // Transaction date
  type          LedgerEntryType     // CHARGE, PAYMENT, CREDIT_NOTE, LATE_FEE, ADJUSTMENT
  description   String              // e.g. "Rent Jul 2025", "M-PESA TH583BXHG8"
  reference     String?             // M-PESA ref, receipt number, etc.
  period        String?             // Rent period this relates to, e.g. "July 2025"

  debit         Decimal  @db.Decimal(10, 2) @default(0)  // Amount charged
  credit        Decimal  @db.Decimal(10, 2) @default(0)  // Amount received/credited
  balance       Decimal  @db.Decimal(10, 2)               // Running balance after this entry

  // Link to actual payment record (for PAYMENT entries)
  paymentId     String?

  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lease         Lease    @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  unit          Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  payment       Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([leaseId])
  @@index([unitId])
  @@index([date])
  @@index([type])
  @@map("tenant_ledger")
}

enum LedgerEntryType {
  CHARGE        // Rent due, service charge, etc.
  PAYMENT       // M-PESA, bank transfer, cash received
  CREDIT_NOTE   // Refund, correction, overpayment applied
  LATE_FEE      // Penalty for late payment
  ADJUSTMENT    // Manual correction
}

// ============================================
// Rent Distribution & Statements
// ============================================

model RentTransaction {
  id                String   @id @default(cuid())
  // paymentId is nullable: months funded by the agent (no tenant payment) have no payment.
  // paymentId is NOT unique: a single lump-sum payment (e.g. 60k) can cover multiple months.
  paymentId         String?

  // Core chain: transactionId + tenantId + unitId fully identifies a transaction.
  // landlordId and propertyId are denormalized from unit for query performance —
  // they are set automatically from the unit when a transaction is created.
  tenantId          String
  unitId            String   // FK to Unit → auto-derives landlordId + propertyId
  leaseId           String
  landlordId        String   // denormalized from unit.landlordId
  propertyId        String   // denormalized from unit.propertyId

  // Rent Details
  grossRent         Decimal  @db.Decimal(10, 2)
  rentPeriod        String   // e.g., "November 2025"
  dueDate           DateTime
  paidDate          DateTime?

  // Deductions
  serviceCharge     Decimal  @db.Decimal(10, 2) @default(0) // Monthly service charge
  managementFee     Decimal  @db.Decimal(10, 2) @default(0) // Management commission
  maintenanceFees   Decimal  @db.Decimal(10, 2) @default(0) // Agreed maintenance costs
  otherDeductions   Decimal  @db.Decimal(10, 2) @default(0) // Other agreed deductions
  totalDeductions   Decimal  @db.Decimal(10, 2)

  // Net Amount
  netAmount         Decimal  @db.Decimal(10, 2) // Amount paid to landlord

  // Late Fees (Property Manager Income — not shown to landlord)
  lateFees          Decimal  @db.Decimal(10, 2) @default(0)

  // Payout Details
  payoutId          String?
  payoutStatus      PayoutStatus @default(PENDING)
  payoutDate        DateTime?
  payoutMethod      PaymentMethod?
  payoutReference   String?

  // Metadata
  notes             String?
  processed         Boolean  @default(false)
  processedAt       DateTime?
  processedBy       String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  payment           Payment?  @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unit              Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  lease             Lease    @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  landlord          Landlord @relation(fields: [landlordId], references: [id], onDelete: Cascade)
  property          Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  payout            Payout?  @relation(fields: [payoutId], references: [id], onDelete: SetNull)
  distributionItems RentDistributionItem[]

  @@index([paymentId])
  @@index([tenantId])
  @@index([unitId])
  @@index([leaseId])
  @@index([landlordId])
  @@index([propertyId])
  @@index([rentPeriod])
  @@index([payoutStatus])
  @@map("rent_transactions")
}

model RentDistributionItem {
  id                  String   @id @default(cuid())
  rentTransactionId   String
  // Direct unit link — service charge, repairs, agent commission are all
  // for a specific unit regardless of which transaction they belong to.
  unitId              String

  // Distribution Details
  type                DistributionType  // SERVICE_CHARGE | MANAGEMENT_FEE | MAINTENANCE_FEE | REPAIR_COST | NET_PAYOUT etc.
  description         String
  amount              Decimal  @db.Decimal(10, 2)
  recipientType       RecipientType     // LANDLORD | MANAGER | SERVICE_PROVIDER | VENDOR etc.
  recipientId         String?
  recipientName       String?

  // Payment Details
  paid                Boolean  @default(false)
  paidDate            DateTime?
  paymentMethod       PaymentMethod?
  reference           String?  @unique  // receipt/transaction ID for this specific line item

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  rentTransaction     RentTransaction @relation(fields: [rentTransactionId], references: [id], onDelete: Cascade)
  unit                Unit            @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([rentTransactionId])
  @@index([unitId])
  @@index([type])
  @@index([recipientType])
  @@map("rent_distribution_items")
}

model LandlordStatement {
  id              String   @id @default(cuid())
  landlordId      String
  propertyId      String?
  
  // Statement Period
  period          String   // e.g., "November 2025"
  startDate       DateTime
  endDate         DateTime
  
  // Financial Summary
  totalGrossRent       Decimal  @db.Decimal(10, 2)
  totalServiceCharges  Decimal  @db.Decimal(10, 2)
  totalManagementFees  Decimal  @db.Decimal(10, 2)
  totalMaintenanceFees Decimal  @db.Decimal(10, 2)
  totalOtherDeductions Decimal  @db.Decimal(10, 2)
  totalDeductions      Decimal  @db.Decimal(10, 2)
  totalNetAmount       Decimal  @db.Decimal(10, 2)
  
  // Metadata
  transactionCount Int      @default(0)
  generated        Boolean  @default(false)
  generatedAt      DateTime?
  generatedBy      String?
  sent             Boolean  @default(false)
  sentAt           DateTime?
  
  // Export
  pdfUrl           String?
  
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  landlord         Landlord @relation(fields: [landlordId], references: [id], onDelete: Cascade)
  property         Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  @@unique([landlordId, period, propertyId])
  @@index([landlordId])
  @@index([period])
  @@index([startDate, endDate])
  @@map("landlord_statements")
}

model OwnerStatement {
  id              String   @id @default(cuid())
  landlordId      String
  propertyId      String?  // null = consolidated portfolio statement

  month           Int      // 1-12
  year            Int

  // Revenue
  rentDue         Decimal  @db.Decimal(10, 2)
  rentReceived    Decimal  @db.Decimal(10, 2)

  // Deductions
  managementFee   Decimal  @db.Decimal(10, 2)
  managementFeeRate Decimal @db.Decimal(5, 2) // percentage
  maintenanceCosts Decimal @db.Decimal(10, 2) @default(0)
  otherDeductions Decimal  @db.Decimal(10, 2) @default(0)

  // Result
  netDisbursement Decimal  @db.Decimal(10, 2)
  depositsHeld    Decimal  @db.Decimal(10, 2) @default(0)

  // Line items detail
  lineItems       Json?    // Array: [{description, amount, type: 'income'|'deduction'}]

  // Status
  status          StatementStatus @default(DRAFT)
  generatedAt     DateTime @default(now())
  sentAt          DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  landlord        Landlord @relation(fields: [landlordId], references: [id])
  property        Property? @relation(fields: [propertyId], references: [id])

  @@unique([landlordId, propertyId, month, year])
  @@index([landlordId])
  @@index([propertyId])
  @@index([month, year])
  @@map("owner_statements")
}

enum StatementStatus {
  DRAFT
  FINALIZED
  SENT
}

// ============================================
// Deposits
// ============================================

model Deposit {
  id              String   @id @default(cuid())
  tenantId        String
  leaseId         String
  propertyId      String
  amount          Decimal  @db.Decimal(10, 2)
  paymentDate     DateTime
  paymentMethod   PaymentMethod @default(MPESA)
  paymentReference String?
  status          DepositStatus @default(HELD)

  // Settlement
  deductions      Json?    // Array: [{description, amount, evidenceUrl}]
  refundAmount    Decimal? @db.Decimal(10, 2)
  refundDate      DateTime?
  refundReference String?
  settlementNotes String?  @db.Text

  createdAt       DateTime @default(now())
