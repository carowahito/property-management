{
  "framework": "nextjs",
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/arrears-scan",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/generate-invoices",
      "schedule": "0 6 1 * *"
    }
  ]
}
